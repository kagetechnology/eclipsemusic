<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:orientation="vertical"
    android:background="@color/bg">

    <!-- ── Header: gradient + search bar inside ── -->
    <FrameLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:background="@drawable/bg_gradient_header">

        <!-- Glow orb top-right -->
        <View
            android:layout_width="200dp"
            android:layout_height="200dp"
            android:layout_gravity="top|end"
            android:layout_marginTop="-60dp"
            android:layout_marginEnd="-60dp"
            android:background="@drawable/bg_glow_circle"
            android:alpha="0.30" />

        <!-- Glow orb bottom-left -->
        <View
            android:layout_width="140dp"
            android:layout_height="140dp"
            android:layout_gravity="bottom|start"
            android:layout_marginBottom="-40dp"
            android:layout_marginStart="-40dp"
            android:background="@drawable/bg_glow_circle"
            android:alpha="0.25" />

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical"
            android:paddingStart="20dp"
            android:paddingEnd="20dp"
            android:paddingTop="60dp"
            android:paddingBottom="20dp">

            <!-- Label -->
            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="ECLIPSE MUSIC"
                android:textColor="#66ADC7FF"
                android:textSize="11sp"
                android:fontFamily="@font/inter"
                android:textStyle="bold"
                android:letterSpacing="0.25" />

            <!-- Title row -->
            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="horizontal"
                android:gravity="center_vertical"
                android:layout_marginTop="4dp"
                android:layout_marginBottom="16dp">

                <LinearLayout
                    android:layout_width="0dp"
                    android:layout_height="wrap_content"
                    android:layout_weight="1"
                    android:orientation="vertical">

                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="Discover"
                        android:textColor="#FFFFFFFF"
                        android:textSize="32sp"
                        android:fontFamily="@font/inter"
                        android:textStyle="bold" />

                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="Find your next favorite song"
                        android:textColor="#B3FFFFFF"
                        android:textSize="14sp"
                        android:fontFamily="@font/inter"
                        android:layout_marginTop="2dp" />
                </LinearLayout>

                <!-- Decorative music note badge -->
                <FrameLayout
                    android:layout_width="52dp"
                    android:layout_height="52dp"
                    android:background="@drawable/bg_mic_btn">
                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:layout_gravity="center"
                        android:text="♬"
                        android:textSize="22sp"
                        android:textColor="@color/primary" />
                </FrameLayout>
            </LinearLayout>

            <!-- Search bar (inside header, no negative margin) -->
            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="52dp"
                android:orientation="horizontal"
                android:gravity="center_vertical"
                android:background="@drawable/bg_glass"
                android:paddingStart="16dp"
                android:paddingEnd="10dp">

                <ImageView
                    android:layout_width="20dp"
                    android:layout_height="20dp"
                    android:src="@drawable/ic_search"
                    android:tint="@color/primary"
                    android:contentDescription="Search"
                    android:layout_marginEnd="12dp" />

                <EditText
                    android:id="@+id/search_input"
                    android:layout_width="0dp"
                    android:layout_height="match_parent"
                    android:layout_weight="1"
                    android:background="@null"
                    android:hint="Songs, artists, albums..."
                    android:textColorHint="#55FFFFFF"
                    android:textColor="@color/text_primary"
                    android:textSize="15sp"
                    android:imeOptions="actionSearch"
                    android:inputType="text"
                    android:singleLine="true" />

                <ImageView
                    android:id="@+id/search_clear"
                    android:layout_width="20dp"
                    android:layout_height="20dp"
                    android:src="@drawable/ic_close"
                    android:contentDescription="Clear"
                    android:visibility="gone"
                    android:layout_marginEnd="8dp" />

                <FrameLayout
                    android:layout_width="40dp"
                    android:layout_height="40dp"
                    android:background="@drawable/bg_mic_btn"
                    android:clickable="true"
                    android:focusable="true">
                    <ImageView
                        android:id="@+id/search_mic"
                        android:layout_width="18dp"
                        android:layout_height="18dp"
                        android:layout_gravity="center"
                        android:src="@drawable/ic_mic"
                        android:tint="@color/primary"
                        android:contentDescription="Recognize music" />
                </FrameLayout>
            </LinearLayout>

        </LinearLayout>
    </FrameLayout>

    <!-- ── Loading ── -->
    <ProgressBar
        android:id="@+id/search_loading"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:layout_gravity="center_horizontal"
        android:layout_marginTop="32dp"
        android:indeterminateTint="@color/primary"
        android:visibility="gone" />

    <!-- ── Browse / Empty State ── -->
    <ScrollView
        android:id="@+id/browse_section"
        android:layout_width="match_parent"
        android:layout_height="0dp"
        android:layout_weight="1"
        android:scrollbars="none"
        android:visibility="visible">

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical"
            android:paddingTop="20dp"
            android:paddingBottom="20dp">

            <!-- Recommendations based on history -->
            <LinearLayout
                android:id="@+id/search_recommendations_container"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="vertical"
                android:paddingBottom="20dp">

                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="Lagu Rekomendasi"
                    android:textColor="#FFFFFFFF"
                    android:textSize="17sp"
                    android:fontFamily="@font/inter"
                    android:textStyle="bold"
                    android:paddingStart="20dp"
                    android:paddingBottom="12dp" />

                <androidx.recyclerview.widget.RecyclerView
                    android:id="@+id/search_recommendations_list"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:clipToPadding="false"
                    android:paddingStart="16dp"
                    android:paddingEnd="16dp"
                    android:orientation="horizontal" />
            </LinearLayout>



            <!-- Divider -->
            <View
                android:layout_width="match_parent"
                android:layout_height="1dp"
                android:background="#0DFFFFFF"
                android:layout_marginStart="20dp"
                android:layout_marginEnd="20dp"
                android:layout_marginBottom="16dp" />

            <!-- Browse header -->
            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="horizontal"
                android:gravity="center_vertical"
                android:paddingStart="20dp"
                android:paddingEnd="20dp"
                android:paddingBottom="14dp">

                <View
                    android:layout_width="4dp"
                    android:layout_height="18dp"
                    android:background="@drawable/bg_section_accent"
                    android:layout_marginEnd="10dp" />

                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="Browse by genre"
                    android:textColor="@color/text_primary"
                    android:textSize="19sp"
                    android:fontFamily="@font/inter"
                    android:textStyle="bold" />
            </LinearLayout>

            <!-- Chips: Bento Grid -->
            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="vertical"
                android:paddingStart="16dp"
                android:paddingEnd="16dp"
                android:paddingBottom="40dp">

                <!-- Row 1: Full width -->
                <FrameLayout
                    android:id="@+id/chip_trending"
                    android:layout_width="match_parent"
                    android:layout_height="120dp"
                    android:layout_marginBottom="12dp"
                    android:background="@drawable/bg_browse_chip_purple"
                    android:clickable="true"
                    android:focusable="true"
                    android:stateListAnimator="@animator/button_press"
                    android:clipToOutline="true">
                    
                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:layout_gravity="bottom|end"
                        android:layout_marginEnd="-10dp"
                        android:layout_marginBottom="-20dp"
                        android:text="🔥"
                        android:textSize="90sp"
                        android:alpha="0.25" />

                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:layout_gravity="bottom|start"
                        android:layout_marginStart="16dp"
                        android:layout_marginBottom="12dp"
                        android:text="Trending"
                        android:textColor="#FFFFFF"
                        android:textSize="22sp"
                        android:fontFamily="@font/inter"
                        android:textStyle="bold" />
                </FrameLayout>

                <!-- Row 2: 50/50 Split -->
                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="100dp"
                    android:layout_marginBottom="12dp"
                    android:orientation="horizontal">

                    <FrameLayout
                        android:id="@+id/chip_pop"
                        android:layout_width="0dp"
                        android:layout_height="match_parent"
                        android:layout_weight="1"
                        android:layout_marginEnd="6dp"
                        android:background="@drawable/bg_browse_chip_blue"
                        android:clickable="true"
                        android:focusable="true"
                        android:stateListAnimator="@animator/button_press"
                        android:clipToOutline="true">
                        <TextView android:layout_width="wrap_content" android:layout_height="wrap_content" android:layout_gravity="top|end" android:layout_marginTop="-10dp" android:layout_marginEnd="-10dp" android:text="🎤" android:textSize="70sp" android:alpha="0.25" />
                        <TextView android:layout_width="wrap_content" android:layout_height="wrap_content" android:layout_gravity="bottom|start" android:layout_marginStart="12dp" android:layout_marginBottom="10dp" android:text="Pop" android:textColor="#FFFFFF" android:textSize="18sp" android:fontFamily="@font/inter" android:textStyle="bold" />
                    </FrameLayout>

                    <FrameLayout
                        android:id="@+id/chip_hiphop"
                        android:layout_width="0dp"
                        android:layout_height="match_parent"
                        android:layout_weight="1"
                        android:layout_marginStart="6dp"
                        android:background="@drawable/bg_browse_chip_warm"
                        android:clickable="true"
                        android:focusable="true"
                        android:stateListAnimator="@animator/button_press"
                        android:clipToOutline="true">
                        <TextView android:layout_width="wrap_content" android:layout_height="wrap_content" android:layout_gravity="top|end" android:layout_marginTop="-10dp" android:layout_marginEnd="-10dp" android:text="🎧" android:textSize="70sp" android:alpha="0.25" />
                        <TextView android:layout_width="wrap_content" android:layout_height="wrap_content" android:layout_gravity="bottom|start" android:layout_marginStart="12dp" android:layout_marginBottom="10dp" android:text="Hip-Hop" android:textColor="#FFFFFF" android:textSize="18sp" android:fontFamily="@font/inter" android:textStyle="bold" />
                    </FrameLayout>
                </LinearLayout>

                <!-- Row 3: Staggered (1 Tall, 2 Stacked) -->
                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="212dp"
                    android:orientation="horizontal">

                    <!-- Tall Left -->
                    <FrameLayout
                        android:id="@+id/chip_electronic"
                        android:layout_width="0dp"
                        android:layout_height="match_parent"
                        android:layout_weight="1"
                        android:layout_marginEnd="6dp"
                        android:background="@drawable/bg_browse_chip_green"
                        android:clickable="true"
                        android:focusable="true"
                        android:stateListAnimator="@animator/button_press"
                        android:clipToOutline="true">
                        <TextView android:layout_width="wrap_content" android:layout_height="wrap_content" android:layout_gravity="bottom|end" android:layout_marginEnd="-15dp" android:layout_marginBottom="-10dp" android:text="⚡" android:textSize="110sp" android:alpha="0.25" />
                        <TextView android:layout_width="wrap_content" android:layout_height="wrap_content" android:layout_gravity="top|start" android:layout_marginStart="12dp" android:layout_marginTop="16dp" android:text="Electronic" android:textColor="#FFFFFF" android:textSize="20sp" android:fontFamily="@font/inter" android:textStyle="bold" />
                    </FrameLayout>

                    <!-- Stacked Right -->
                    <LinearLayout
                        android:layout_width="0dp"
                        android:layout_height="match_parent"
                        android:layout_weight="1"
                        android:layout_marginStart="6dp"
                        android:orientation="vertical">

                        <FrameLayout
                            android:id="@+id/chip_rnb"
                            android:layout_width="match_parent"
                            android:layout_height="0dp"
                            android:layout_weight="1"
                            android:layout_marginBottom="12dp"
                            android:background="@drawable/bg_browse_chip_purple"
                            android:clickable="true"
                            android:focusable="true"
                            android:stateListAnimator="@animator/button_press"
                            android:clipToOutline="true">
                            <TextView android:layout_width="wrap_content" android:layout_height="wrap_content" android:layout_gravity="top|end" android:layout_marginTop="-5dp" android:layout_marginEnd="-5dp" android:text="🎵" android:textSize="60sp" android:alpha="0.25" />
                            <TextView android:layout_width="wrap_content" android:layout_height="wrap_content" android:layout_gravity="bottom|start" android:layout_marginStart="12dp" android:layout_marginBottom="10dp" android:text="R&amp;B" android:textColor="#FFFFFF" android:textSize="18sp" android:fontFamily="@font/inter" android:textStyle="bold" />
                        </FrameLayout>

                        <FrameLayout
                            android:id="@+id/chip_lofi"
                            android:layout_width="match_parent"
                            android:layout_height="0dp"
                            android:layout_weight="1"
                            android:background="@drawable/bg_browse_chip_blue"
                            android:clickable="true"
                            android:focusable="true"
                            android:stateListAnimator="@animator/button_press"
                            android:clipToOutline="true">
                            <TextView android:layout_width="wrap_content" android:layout_height="wrap_content" android:layout_gravity="top|end" android:layout_marginTop="-5dp" android:layout_marginEnd="-5dp" android:text="☕" android:textSize="60sp" android:alpha="0.25" />
                            <TextView android:layout_width="wrap_content" android:layout_height="wrap_content" android:layout_gravity="bottom|start" android:layout_marginStart="12dp" android:layout_marginBottom="10dp" android:text="Lo-Fi" android:textColor="#FFFFFF" android:textSize="18sp" android:fontFamily="@font/inter" android:textStyle="bold" />
                        </FrameLayout>
                    </LinearLayout>
                </LinearLayout>
            </LinearLayout>
        </LinearLayout>
    </ScrollView>

    <!-- ── Search Results ── -->
    <androidx.recyclerview.widget.RecyclerView
        android:id="@+id/search_results"
        android:layout_width="match_parent"
        android:layout_height="0dp"
        android:layout_weight="1"
        android:visibility="gone" />

    <!-- Search Empty State (No results) -->
    <TextView
        android:id="@+id/search_empty"
        android:layout_width="match_parent"
        android:layout_height="0dp"
        android:layout_weight="1"
        android:text=""
        android:textColor="#B3FFFFFF"
        android:textSize="15sp"
        android:fontFamily="@font/inter"
        android:gravity="center"
        android:visibility="gone"
        android:layout_marginTop="32dp" />

</LinearLayout>
