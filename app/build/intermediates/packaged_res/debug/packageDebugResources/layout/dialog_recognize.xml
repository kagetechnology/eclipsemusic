<?xml version="1.0" encoding="utf-8"?>
<RelativeLayout xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="#0A0A0C">

    <!-- Top Bar -->
    <LinearLayout
        android:id="@+id/top_bar"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="horizontal"
        android:paddingStart="16dp"
        android:paddingEnd="16dp"
        android:paddingTop="32dp"
        android:paddingBottom="16dp"
        android:gravity="center_vertical">
        
        <ImageView
            android:id="@+id/btn_back_recognize"
            android:layout_width="32dp"
            android:layout_height="32dp"
            android:src="@drawable/ic_chevron_down"
            android:rotation="90"
            android:padding="4dp"
            android:tint="#FFFFFF"
            android:clickable="true"
            android:focusable="true"
            android:stateListAnimator="@animator/button_press" />
            
        <TextView
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_weight="1"
            android:text="Recognize Music"
            android:textColor="#FFFFFF"
            android:textSize="20sp"
            android:fontFamily="@font/inter"
            android:layout_marginStart="16dp" />
            
        <ImageView
            android:layout_width="32dp"
            android:layout_height="32dp"
            android:src="@drawable/ic_history"
            android:padding="4dp"
            android:tint="#FFFFFF"
            android:clickable="true"
            android:focusable="true"
            android:stateListAnimator="@animator/button_press" />
    </LinearLayout>

    <!-- Center Content -->
    <RelativeLayout
        android:layout_width="match_parent"
        android:layout_height="match_parent"
        android:layout_below="@id/top_bar">

        <!-- Glowing Mic Rings Container -->
        <FrameLayout
            android:id="@+id/mic_container"
            android:layout_width="250dp"
            android:layout_height="250dp"
            android:layout_centerInParent="true"
            android:layout_marginTop="-100dp">
            
            <!-- Outer Ring -->
            <View
                android:id="@+id/mic_ring_outer"
                android:layout_width="250dp"
                android:layout_height="250dp"
                android:background="@drawable/bg_circle_translucent"
                android:layout_gravity="center"
                android:alpha="0.2" />
                
            <!-- Inner Ring -->
            <View
                android:id="@+id/mic_ring_inner"
                android:layout_width="190dp"
                android:layout_height="190dp"
                android:background="@drawable/bg_circle_translucent"
                android:layout_gravity="center"
                android:alpha="0.5" />

            <!-- Core Mic Button -->
            <FrameLayout
                android:id="@+id/mic_glow"
                android:layout_width="130dp"
                android:layout_height="130dp"
                android:background="@drawable/bg_circle_solid_purple"
                android:layout_gravity="center">
                <ImageView
                    android:layout_width="54dp"
                    android:layout_height="54dp"
                    android:src="@drawable/ic_mic"
                    android:tint="#16161A"
                    android:layout_gravity="center" />
            </FrameLayout>
        </FrameLayout>

        <TextView
            android:id="@+id/recognize_text"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:text="Listening..."
            android:textColor="#C4C8F5"
            android:textSize="18sp"
            android:fontFamily="@font/inter"
            android:textStyle="bold"
            android:gravity="center"
            android:layout_below="@id/mic_container"
            android:layout_marginTop="32dp" />

        <TextView
            android:id="@+id/btn_cancel_recognize"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="Cancel"
            android:textColor="#FFFFFF"
            android:textSize="16sp"
            android:fontFamily="@font/inter"
            android:background="@drawable/bg_button_outline"
            android:paddingStart="24dp"
            android:paddingEnd="24dp"
            android:paddingTop="10dp"
            android:paddingBottom="10dp"
            android:layout_below="@id/recognize_text"
            android:layout_centerHorizontal="true"
            android:layout_marginTop="24dp"
            android:clickable="true"
            android:focusable="true"
            android:stateListAnimator="@animator/button_press" />
            
    </RelativeLayout>
</RelativeLayout>
